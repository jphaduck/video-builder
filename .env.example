# This file documents the environment variables expected by Story Video Studio.
# Never put real secrets in this file.
# OPENAI_API_KEY powers chat generation, TTS narration, and Whisper captions.
# ELEVENLABS_API_KEY is still optional/future-facing while OpenAI is the active voice stack.

OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
